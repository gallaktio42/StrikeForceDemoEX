<Window x:Class="DemoExam.Views.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DemoExam.Views"
        mc:Ignorable="d"
        Title="Реадактирование товара" Height="700" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- фото метка -->
            <RowDefinition Height="Auto"/>
            <!-- фото -->
            <RowDefinition Height="Auto"/>
            <!-- кнопка загрузки -->
            <RowDefinition Height="Auto"/>
            <!-- наименование -->
            <RowDefinition Height="Auto"/>
            <!-- категория -->
            <RowDefinition Height="Auto"/>
            <!-- описание -->
            <RowDefinition Height="Auto"/>
            <!-- производитель -->
            <RowDefinition Height="Auto"/>
            <!-- поставщик -->
            <RowDefinition Height="Auto"/>
            <!-- цена -->
            <RowDefinition Height="Auto"/>
            <!-- ед. изм. -->
            <RowDefinition Height="Auto"/>
            <!-- кол-во -->
            <RowDefinition Height="Auto"/>
            <!-- скидка -->
            <RowDefinition Height="Auto"/>
            <!-- кнопки -->
            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Информация о товаре" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Text="Фото:" VerticalAlignment="Center"/>
        <Image x:Name="imgPreview" Grid.Row="1" Grid.Column="1" Width="150" Height="100" Stretch="Uniform" Margin="5"/>

        <Button Grid.Row="2" Grid.Column="1" Content="Загрузить фото" Width="120" Click="LoadImage_Click" HorizontalAlignment="Left" Margin="5,0,0,5"/>

        <TextBlock Grid.Row="3" Text="Наименование:" VerticalAlignment="Center"/>
        <TextBox x:Name="txtName" Grid.Row="3" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="4" Text="Категория:" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbCategory" Grid.Row="4" Grid.Column="1" DisplayMemberPath="CategoryName" SelectedValuePath="CategoryID" Margin="5"/>

        <TextBlock Grid.Row="5" Text="Артикул:" VerticalAlignment="Center"/>
        <TextBox x:Name="txtArticleNumber" Grid.Row="5" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="6" Text="Описание:" VerticalAlignment="Top" Margin="0,5,0,0"/>
        <TextBox x:Name="txtDescription" Grid.Row="6" Grid.Column="1" Height="60" TextWrapping="Wrap" Margin="5"/>

        <TextBlock Grid.Row="7" Text="Производитель:" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbManufacturer" Grid.Row="7" Grid.Column="1" DisplayMemberPath="ManufacturerName" SelectedValuePath="ManufacturerID" Margin="5"/>

        <TextBlock Grid.Row="8" Text="Поставщик:" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbSupplier" Grid.Row="8" Grid.Column="1" DisplayMemberPath="SupplierName" SelectedValuePath="SupplierID" Margin="5"/>

        <TextBlock Grid.Row="9" Text="Цена:" VerticalAlignment="Center"/>
        <TextBox x:Name="txtPrice" Grid.Row="9" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="10" Text="Ед. изм.:" VerticalAlignment="Center"/>
        <TextBox x:Name="txtUnit" Grid.Row="10" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="11" Text="Кол-во на складе:" VerticalAlignment="Center"/>
        <TextBox x:Name="txtStock" Grid.Row="11" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="12" Text="Скидка (%):" VerticalAlignment="Center"/>
        <TextBox x:Name="txtDiscount" Grid.Row="12" Grid.Column="1" Margin="5"/>

        <StackPanel Grid.Row="13" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10,20,10,10">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="40" Margin="10" Click="Save_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="40" Margin="10" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
