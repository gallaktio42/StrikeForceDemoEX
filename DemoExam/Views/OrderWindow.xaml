<Window x:Class="DemoExam.Views.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DemoExam.Views"
        mc:Ignorable="d"
        Title="Заказы" Height="500" Width="900"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Верхняя панель с кнопкой Назад и CRUD -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10" Background="LightGray">
            <Button x:Name="btnBack" Content="Назад" Width="80" Margin="0,0,10,0" Click="BtnBack_Click"/>
            <TextBlock Text="Список заказов" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,20,0"/>

            <!-- Кнопки CRUD -->
            <Button x:Name="btnAdd" Content="Добавить" Width="80" Margin="5,0" Click="BtnAdd_Click" Visibility="Collapsed"/>
            <Button x:Name="btnEdit" Content="Редактировать" Margin="5,0" Click="BtnEdit_Click" Visibility="Collapsed"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="80" Margin="5,0" Click="BtnDelete_Click" Visibility="Collapsed"/>
        </StackPanel>

        <!-- Таблица заказов -->
        <DataGrid x:Name="dgOrders" AutoGenerateColumns="False" IsReadOnly="True" Margin="10" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Артикул" Binding="{Binding OrderNumber}" Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status.StatusName}" Width="120"/>
                <DataGridTextColumn Header="Адрес пункта выдачи" Binding="{Binding PickupPoint.Address}" Width="*"/>
                <DataGridTextColumn Header="Дата заказа" Binding="{Binding OrderDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                <DataGridTextColumn Header="Дата выдачи" Binding="{Binding IssueDate, StringFormat=dd.MM.yyyy}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
